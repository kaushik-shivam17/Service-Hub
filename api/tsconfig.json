{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2022"],
    "types": ["node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "outDir": "../dist/api"
  },
  "include": ["."],
  "references": [
    { "path": "../artifacts/api-server" },
    { "path": "../lib/db" },
    { "path": "../lib/api-zod" }
  ]
}
